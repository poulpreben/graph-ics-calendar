# Microsoft Entra ID app registration (delegated permissions: Calendars.Read)
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_CLIENT_SECRET=your-client-secret
# Use your tenant ID for single-tenant apps, or "common" / "organizations" for multi-tenant
MS_TENANT_ID=common

# Public URL where this service is reachable (used as the OAuth redirect base).
# The callback URL registered in Entra must be ${PUBLIC_BASE_URL}/auth/callback
PUBLIC_BASE_URL=http://localhost:8000

# SQLite database path. Stores the MSAL refresh-token cache (encrypted with
# GRAPH_ICS_CACHE_KEY, see below) plus per-user sync state and cached calendar
# events. The file is also created with mode 0600.
DATABASE_PATH=./data/tokens.sqlite3

# Fernet key (urlsafe base64, 32 bytes) used to encrypt the MSAL refresh-token
# cache at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this OUT of the database directory and any backups that include the DB.
# Losing it forces all users to re-authenticate.
GRAPH_ICS_CACHE_KEY=

# How far back / forward to fetch events.
ICS_PAST_DAYS=30
ICS_FUTURE_DAYS=365

# Background sync cadence: every 10 minutes.
SYNC_INTERVAL_SECONDS=600

# Force a full (non-delta) resync at least this often, so the date window
# stays current. Default: 24 hours.
FULL_RESYNC_AFTER_SECONDS=86400

# HTTP server bind.
HOST=127.0.0.1
PORT=8000
